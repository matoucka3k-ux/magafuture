/* pages/checkout.module.css */

.main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 60px 24px 80px;
}

.header {
  margin-bottom: 48px;
}

.sectionLabel {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  display: block;
  margin-bottom: 8px;
}

.title {
  font-family: var(--font-display);
  font-size: clamp(40px, 6vw, 72px);
  letter-spacing: 4px;
  color: var(--off-white);
  line-height: 0.9;
}

.layout {
  display: grid;
  grid-template-columns: 1fr 440px;
  gap: 48px;
  align-items: start;
}

/* ORDER SUMMARY */
.orderSummary {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 32px;
}

.summaryHeading {
  font-family: var(--font-display);
  font-size: 28px;
  letter-spacing: 2px;
  color: var(--off-white);
  margin-bottom: 24px;
}

.itemsList {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 24px;
}

.checkoutItem {
  display: flex;
  align-items: center;
  gap: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}

.checkoutItem:last-child {
  border-bottom: none;
}

.checkoutEmoji {
  font-size: 36px;
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkoutItemInfo {
  flex: 1;
}

.checkoutItemName {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 15px;
  color: var(--off-white);
  margin-bottom: 3px;
}

.checkoutItemMeta {
  font-size: 12px;
  color: var(--warm-grey);
}

.checkoutItemPrice {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 16px;
  color: var(--gold);
  flex-shrink: 0;
}

.summaryFooter {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
  margin-bottom: 20px;
}

.summaryRow {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: var(--warm-grey);
}

.totalRow {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 18px;
  color: var(--off-white);
  padding-top: 8px;
  border-top: 1px solid var(--border);
}

.gold {
  color: var(--gold);
}

.editCart {
  font-family: var(--font-heading);
  font-size: 12px;
  letter-spacing: 1px;
  color: var(--warm-grey);
  transition: color 0.2s;
}

.editCart:hover {
  color: var(--gold);
}

/* PAYMENT BOX */
.paymentBox {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 32px;
  position: sticky;
  top: 80px;
}

.paymentHeading {
  font-family: var(--font-display);
  font-size: 28px;
  letter-spacing: 2px;
  color: var(--off-white);
  margin-bottom: 12px;
}

.paymentNote {
  font-size: 13px;
  color: var(--warm-grey);
  line-height: 1.7;
  margin-bottom: 28px;
}

.paypalWrap {
  margin-bottom: 20px;
  min-height: 56px;
}

.loadingPaypal {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  color: var(--warm-grey);
  font-size: 14px;
}

.spinner {
  width: 20px;
  height: 20px;
  border: 2px solid var(--border);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.paypalFailedLoad {
  background: rgba(200, 16, 46, 0.1);
  border: 1px solid rgba(200, 16, 46, 0.3);
  border-radius: 2px;
  padding: 16px;
  font-size: 13px;
  color: #ff6b6b;
}

.errorMsg {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(200, 16, 46, 0.1);
  border: 1px solid rgba(200, 16, 46, 0.3);
  border-radius: 2px;
  padding: 12px 16px;
  font-size: 13px;
  color: #ff6b6b;
  margin-bottom: 16px;
}

.securityInfo {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}

.securityItem {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12px;
  color: var(--warm-grey);
}

/* EMPTY STATE */
.emptyState {
  max-width: 500px;
  margin: 100px auto;
  padding: 0 24px;
  text-align: center;
}

.emptyState h2 {
  font-family: var(--font-display);
  font-size: 40px;
  letter-spacing: 2px;
  color: var(--off-white);
  margin-bottom: 12px;
}

.emptyState p {
  color: var(--warm-grey);
  margin-bottom: 32px;
}

.btn {
  display: inline-flex;
  align-items: center;
  background: var(--gold);
  color: var(--black);
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 16px 36px;
  border-radius: 2px;
  transition: all 0.2s;
}

.btn:hover {
  background: var(--gold-light);
}

/* SUCCESS */
.success {
  min-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 24px;
}

.successCard {
  max-width: 560px;
  width: 100%;
  text-align: center;
  background: var(--card-bg);
  border: 1px solid rgba(0, 107, 60, 0.4);
  border-radius: 4px;
  padding: 56px 48px;
}

.successIcon {
  width: 72px;
  height: 72px;
  background: var(--green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  color: white;
  margin: 0 auto 28px;
}

.successTitle {
  font-family: var(--font-display);
  font-size: 48px;
  letter-spacing: 3px;
  color: var(--off-white);
  margin-bottom: 12px;
}

.successSub {
  font-size: 15px;
  color: var(--warm-grey);
  margin-bottom: 32px;
}

.orderInfo {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 24px;
  margin-bottom: 24px;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.orderRow {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--warm-grey);
  gap: 16px;
}

.mono {
  font-family: monospace;
  font-size: 12px;
  word-break: break-all;
  color: var(--off-white);
}

.successNote {
  font-size: 13px;
  color: var(--warm-grey);
  line-height: 1.7;
  margin-bottom: 28px;
}

.successNote a {
  color: var(--gold);
  transition: opacity 0.2s;
}

.successNote a:hover {
  opacity: 0.8;
}

@media (max-width: 900px) {
  .layout {
    grid-template-columns: 1fr;
  }
  .paymentBox {
    position: static;
  }
}

@media (max-width: 480px) {
  .successCard {
    padding: 32px 24px;
  }
  .orderRow {
    flex-direction: column;
    gap: 4px;
  }
}
